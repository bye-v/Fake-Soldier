  npcName: "\uC5EC\uC131"
  dialogueLines:
  - speaker: "\uC5EC\uC131"
    text: "\uB0A8\uD3B8\uC774 \uCD9C\uADFC\uD558\uB2E4\uAC00... \uCD1D\uC5D0 \uB9DE\uC558\uC5B4\uC694.
      \uC9C0\uAE08 \uC800\uAE30 \uAE38\uBC14\uB2E5\uC5D0 \uC4F0\uB7EC\uC838 \uC788\uC5B4\uC694."
  - speaker: "\uC5EC\uC131"
    text: "30\uBD84\uC9F8 \uC190\uC73C\uB85C \uB204\uB974\uACE0 \uC788\uC5B4\uC694.
      \uD53C\uAC00 \uC548 \uBA48\uCDB0\uC694. \uBCD1\uC6D0\uC774 \uB450 \uBE14\uB85D\uC774\uC5D0\uC694!"
  - speaker: "\uC5EC\uC131"
    text: "\uC81C\uBC1C\uC694. \uB2F9\uC2E0\uC774 \uB9C9\uACE0 \uC788\uC73C\uBA74
      \uB0A8\uD3B8\uC774 \uC8FD\uC5B4\uC694. \uC9C0\uAE08 \uC8FD\uC5B4\uAC00\uACE0
      \uC788\uB2E4\uACE0\uC694!"
